    base07 = "#43436c"; # pearlBlack2 - Light Background (Not often used)
    base08 = "#b35b79"; # pearlPink - Variables, XML Tags, Markup Link Text, Markup Lists, Diff Deleted
    base09 = "#cc6d00"; # pearlOrange - Integers, Boolean, Constants, XML Attributes, Markup Link Url
    base0A = "#836f4a"; # pearlYellow2 - Classes, Markup Bold, Search Text Background
    base0B = "#6f894e"; # pearlGreen - Strings, Inherited Class, Markup Code, Diff Inserted
